# Database 
# Port 3310 is the local SSM forward for aitools-service
DB_URL=jdbc:mysql://127.0.0.1:3310/costroomdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=admin
DB_PASSWORD=CostRoomDev123

# Cognito (same pool as all other services) 
COGNITO_ISSUER_URI=https://cognito-idp.ap-southeast-2.amazonaws.com/ap-southeast-2_fxW1EzwhJ
COGNITO_JWK_SET_URI=https://cognito-idp.ap-southeast-2.amazonaws.com/ap-southeast-2_fxW1EzwhJ/.well-known/jwks.json

# Encryption key (AES-256, base64-encoded) 
# Generate a fresh key: run EncryptionService.generateBase64AesKey() once and paste here.
# NEVER commit a real production key. Rotate via env var in prod.
ENCRYPTION_KEY=T3kFLvZ3jd0cCHwo86oGr478LCZHpUTo4cX4byAiTkQ=

# Internal service URLs 
ORG_SERVICE_BASE_URL=http://localhost:8082

# Ingestion schedule 
# 1 min 60000
# 5 min 300000
# 10 min 600000
# 15 min 900000
# 30 min 1800000
# 60 min 3600000
# 6 hours 21600000
INGESTION_RATE_MS=300000
